<Window x:Class="BookFair.WPF.Views.BookView.UpdateBook"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:BookFair.WPF.Properties"
        Title="{x:Static properties:Resources.FormTitle_UpdateBook}" Height="480" Width="620"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="BorderBrush" Value="Red"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="ToolTip"
                            Value="{Binding Path=(Validation.Errors)[0].ErrorContent,
                                            RelativeSource={RelativeSource Self},
                                            FallbackValue=''}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Margin="12">

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnSave" Content="{x:Static properties:Resources.FormBtn_Save}" Width="100" Margin="0,0,10,0"
                IsEnabled="False" Click="Save_Click"/>
            <Button Content="{x:Static properties:Resources.FormBtn_Cancel}" Width="100" Click="Close_Click"/>
        </StackPanel>

        <!-- Form -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ISBN -->
            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,2" Text="{x:Static properties:Resources.Form_ISBN}"/>
            <TextBox   Grid.Row="0" Grid.Column="1" Height="24"
                   Text="{Binding Book.ISBN, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                   TextChanged="OnAnyTextChanged"/>

            <!-- Name -->
            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,2" Text="{x:Static properties:Resources.Form_Name}"/>
            <TextBox   Grid.Row="1" Grid.Column="1" Height="24" Margin="0,4,0,0"
                   Text="{Binding Book.Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                   TextChanged="OnAnyTextChanged"/>

            <!-- Genre -->
            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,0,2" Text="{x:Static properties:Resources.Form_Genre}"/>
            <ComboBox  x:Name="GenreComboBox"
                   Grid.Row="2" Grid.Column="1" Height="24" Margin="0,4,0,0"
                   ItemsSource="{Binding GenreDropdownList}"
                   DisplayMemberPath="DisplayName"
                   SelectedValuePath="Value"
                   SelectionChanged="OnGenreSelectionChanged"/>

            <!-- Year of Release -->
            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6,0,2" Text="{x:Static properties:Resources.Form_YearOfRelease}"/>
            <TextBox   Grid.Row="3" Grid.Column="1" Height="24" Margin="0,4,0,0"
                   Text="{Binding Book.YearOfReleaseText, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                   TextChanged="OnAnyTextChanged"/>

            <!-- Price -->
            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6,0,2" Text="{x:Static properties:Resources.Form_Price}"/>
            <TextBox   Grid.Row="4" Grid.Column="1" Height="24" Margin="0,4,0,0"
                   Text="{Binding Book.PriceText, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                   TextChanged="OnAnyTextChanged"/>

            <!-- Number of Pages -->
            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6,0,2" Text="{x:Static properties:Resources.Form_NumberOfPages}"/>
            <TextBox   Grid.Row="5" Grid.Column="1" Height="24" Margin="0,4,0,0"
                   Text="{Binding Book.NumberOfPagesText, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                   TextChanged="OnAnyTextChanged"/>

            <!-- Authors -->
            
            <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,6,0,2" Text="{x:Static properties:Resources.Form_Author}"/>

            <Grid Grid.Row="6" Grid.Column="1" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>

                <!-- Autor* (prazno ako nema autora) -->
                <TextBox Grid.Column="0" Height="24"
             IsReadOnly="True"
             Text="{Binding Book.Authors, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

                <!-- + dodavanje autora -->
                <Button x:Name="BtnAddAuthor" Grid.Column="1" Height="24" Margin="6,0,0,0"
            Content="+" Click="AddAuthor_Click"/>

                <!-- - uklanjanje autora -->
                <Button x:Name="BtnRemoveAuthor" Grid.Column="2" Height="24" Margin="6,0,0,0"
            Content="-" Click="RemoveAuthor_Click"/>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
