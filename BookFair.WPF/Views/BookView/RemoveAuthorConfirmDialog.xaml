<Window x:Class="BookFair.WPF.Views.BookView.RemoveAuthorConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:BookFair.WPF.Properties"
        Title="{x:Static properties:Resources.FormTitle_RemoveAuthorConfirm}"
        Height="170" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{x:Static properties:Resources.Msg_RemoveAuthorConfirm}"
                   TextWrapping="Wrap"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,18,0,0">
            <Button Content="{x:Static properties:Resources.FormBtn_Cancel}"
                    Width="110"
                    Margin="0,0,10,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>

            <Button Content="{x:Static properties:Resources.FormBtn_ConfirmRemoveAuthor}"
                    Width="110"
                    IsDefault="True"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
