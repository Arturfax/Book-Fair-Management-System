<Window x:Class="BookFair.WPF.Views.PublisherView.PublisherBooks"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:BookFair.WPF.Properties"
        Title="{x:Static properties:Resources.PublisherBooks_WindowDefaultTitle}"
        Height="500"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel LastChildFill="True"
               Margin="12">
        <!-- Search and Close -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">
            <TextBlock VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Text="{x:Static properties:Resources.PublisherBooks_SearchLabel}"/>
            <TextBox x:Name="SearchBox"
                     Width="300"
                     Height="24"
                     TextChanged="SearchBox_TextChanged"/>
            <Button Content="{x:Static properties:Resources.FormBtn_Cancel}"
                    Width="100"
                    Margin="12,0,0,0"
                    Click="Close_Click"/>
        </StackPanel>

        <!-- Data grid of filtered books -->
        <DataGrid DockPanel.Dock="Bottom"
                  x:Name="BooksGrid"
                  ItemsSource="{Binding FilteredBooks}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static properties:Resources.GridBooks_ISBN}"
                                    Binding="{Binding ISBN}"
                                    Width="*"/>
                <DataGridTextColumn Header="{x:Static properties:Resources.GridBooks_Name}"
                                    Binding="{Binding Name}"
                                    Width="2*"/>
                <DataGridTextColumn Header="{x:Static properties:Resources.GridBooks_Price}"
                                    Binding="{Binding Price}"
                                    Width="*"/>
                <DataGridTextColumn Header="{x:Static properties:Resources.GridBooks_YearOfRelease}"
                                    Binding="{Binding YearOfRelease}"
                                    Width="*"/>
                <DataGridTextColumn Header="{x:Static properties:Resources.GridBooks_Genre}"
                                    Binding="{Binding Genre}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>