<Window x:Class="BookFair.WPF.Views.PublisherView.PublisherAuthors"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:BookFair.WPF.Properties"
        Title="Autori izdavača"
        Height="500"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel LastChildFill="True"
               Margin="12">

        <!-- Search + Close -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">
            <TextBlock VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Text="{x:Static properties:Resources.PublisherBooks_SearchLabel}"/>
            <TextBox x:Name="SearchBox"
                     Width="300"
                     Height="24"
                     TextChanged="SearchBox_TextChanged"/>

            <Button Content="{x:Static properties:Resources.FormBtn_Cancel}"
                    Width="100"
                    Margin="12,0,0,0"
                    Click="Close_Click"/>
        </StackPanel>

        <!-- Authors table -->
        <DataGrid x:Name="AuthorsGrid"
                  ItemsSource="{Binding FilteredAuthors}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static properties:Resources.GridAuthors_Name}"
                                    Binding="{Binding Name}"
                                    Width="*"/>
                <DataGridTextColumn Header="{x:Static properties:Resources.GridAuthors_Surname}"
                                    Binding="{Binding Surname}"
                                    Width="*"/>
                <DataGridTextColumn Header="{x:Static properties:Resources.GridAuthors_DateOfBirth}"
                                    Binding="{Binding DateOfBirth}"
                                    Width="*"/>
                <DataGridTextColumn Header="{x:Static properties:Resources.Form_Address}"
                                    Binding="{Binding Address}"
                                    Width="2*"/>
                <DataGridTextColumn Header="{x:Static properties:Resources.Form_Phone}"
                                    Binding="{Binding Phone}"
                                    Width="*"/>
                <DataGridTextColumn Header="{x:Static properties:Resources.GridAuthors_Email}"
                                    Binding="{Binding Email}"
                                    Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
