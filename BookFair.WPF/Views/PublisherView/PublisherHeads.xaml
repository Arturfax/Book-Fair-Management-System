<Window x:Class="BookFair.WPF.Views.PublisherView.PublisherHeads"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:BookFair.WPF.Properties"
        Title="{x:Static properties:Resources.PublisherHeads_WindowTitle}"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    <DockPanel LastChildFill="True"
               Margin="12">

        <!-- Close Button -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="{x:Static properties:Resources.MenuClose}"
                    Width="100"
                    Click="Close_Click"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Publishers List -->
            <DockPanel Grid.Column="0"
                       Margin="0,0,12,0">
                <TextBlock DockPanel.Dock="Top"
                           FontWeight="Bold"
                           Margin="0,0,0,8"
                           Text="{x:Static properties:Resources.PublisherHeads_LabelPublishers}"/>
                <ListBox x:Name="PublishersListBox"
                         DisplayMemberPath="Name"
                         SelectionChanged="PublishersListBox_SelectionChanged"/>
            </DockPanel>

            <!-- Authors and Set Head -->
            <DockPanel Grid.Column="1">
                <TextBlock DockPanel.Dock="Top"
                           FontWeight="Bold"
                           Margin="0,0,0,8"
                           Text="{x:Static properties:Resources.PublisherHeads_LabelAuthors}"/>

                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            Margin="0,12,0,0">
                    <Button Content="{x:Static properties:Resources.PublisherHeads_BtnSetHead}"
                            Width="110"
                            Click="SetAsHead_Click"/>
                </StackPanel>

                <ListBox x:Name="AuthorsListBox"
                         DisplayMemberPath="DisplayName"
                         SelectionChanged="AuthorsListBox_SelectionChanged"/>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
