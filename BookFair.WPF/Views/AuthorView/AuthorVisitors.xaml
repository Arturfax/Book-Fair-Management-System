<Window x:Class="BookFair.WPF.Views.AuthorView.AuthorVisitors"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:BookFair.WPF.Properties"
        Title="{x:Static properties:Resources.AuthorVisitors_WindowDefaultTitle}"
        Height="500"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
        <DockPanel LastChildFill="True"
                   Margin="12">

                <!-- Search and Buttons -->
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0,0,0,12">
                        <TextBlock VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Text="{x:Static properties:Resources.PublisherBooks_SearchLabel}"/>
                        <TextBox x:Name="SearchBox"
                                 Width="300"
                                 Height="24"
                                 TextChanged="SearchBox_TextChanged"/>
                        <Button Content="{x:Static properties:Resources.MenuClose}"
                                Width="100"
                                Margin="12,0,0,0"
                                Click="Close_Click"/>
                </StackPanel>

                <!-- Data Grid -->
                <DataGrid DockPanel.Dock="Bottom"
                          x:Name="VisitorsGrid"
                          ItemsSource="{Binding FilteredVisitors}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                        <DataGrid.Columns>
                                <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_MembershipCardNumber}"
                                                    Binding="{Binding CardNumber}"
                                                    Width="120"/>
                                <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_Name}"
                                                    Binding="{Binding Name}"
                                                    Width="150"/>
                                <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_Surname}"
                                                    Binding="{Binding Surname}"
                                                    Width="150"/>
                                <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_Status}"
                                                    Binding="{Binding Status}"
                                                    Width="100"/>
                                <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_Address}"
                                                    Binding="{Binding Address}"
                                                    Width="*"/>
                        </DataGrid.Columns>
                </DataGrid>
        </DockPanel>
</Window>
