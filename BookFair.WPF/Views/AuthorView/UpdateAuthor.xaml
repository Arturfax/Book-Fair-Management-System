<Window x:Class="BookFair.WPF.Views.AuthorView.UpdateAuthor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:BookFair.WPF.Properties"
        Title="{x:Static properties:Resources.FormTitle_UpdateAuthor}"
        Height="560"
        Width="620"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError"
                        Value="true">
                    <Setter Property="BorderBrush"
                            Value="Red"/>
                    <Setter Property="BorderThickness"
                            Value="2"/>
                    <Setter Property="ToolTip"
                            Value="{Binding Path=(Validation.Errors)[0].ErrorContent,
                                            RelativeSource={RelativeSource Self},
                                            FallbackValue=''}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True"
            Margin="12">

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                    HorizontalAlignment="Right"
                Margin="0,12,0,0">
            <Button x:Name="BtnSave"
                    Content="{x:Static properties:Resources.FormBtn_Save}"
                    Width="100"
                    Margin="0,0,10,0"
                    IsEnabled="False"
                    Click="Save_Click"/>
            <Button Content="{x:Static properties:Resources.FormBtn_Cancel}"
                    Width="100"
                    Click="Close_Click"/>
        </StackPanel>

        <!-- Tabs -->
        <TabControl>
            <TabItem Header="{x:Static properties:Resources.FormTab_Information}">
                <!-- Form -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Name -->
                    <TextBlock Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,2"
                            Text="{x:Static properties:Resources.Form_Name}"/>
                    <TextBox   Grid.Row="0"
                            Grid.Column="1"
                            Height="24"
                               Text="{Binding Author.Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                               TextChanged="OnAnyTextChanged"/>

                    <!-- Surname -->
                    <TextBlock Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,6,0,2"
                            Text="{x:Static properties:Resources.Form_Surname}"/>
                    <TextBox   Grid.Row="1"
                            Grid.Column="1"
                            Height="24"
                            Margin="0,4,0,0"
                               Text="{Binding Author.Surname, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                               TextChanged="OnAnyTextChanged"/>

                    <!-- Date of Birth -->
                    <TextBlock Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,6,0,2"
                            Text="{x:Static properties:Resources.Form_DateOfBirth}"/>
                    <DatePicker Grid.Row="2"
                            Grid.Column="1"
                            Height="24"
                            Margin="0,4,0,0"
                                SelectedDate="{Binding Author.DateOfBirth, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                SelectedDateChanged="OnAnyTextChanged"/>

                    <!-- Address -->
                    <GroupBox Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Header="{x:Static properties:Resources.Form_Address}"
                            Margin="0,8,0,0">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="0,2"
                                    Text="{x:Static properties:Resources.Form_Street}"/>
                            <TextBox   Grid.Row="0"
                                    Grid.Column="1"
                                    Height="24"
                                       Text="{Binding Address.Street, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                       TextChanged="OnAnyTextChanged"/>

                            <TextBlock Grid.Row="0"
                                    Grid.Column="2"
                                    Margin="12,2,0,2"
                                    Text="{x:Static properties:Resources.Form_Number}"/>
                            <TextBox   Grid.Row="0"
                                    Grid.Column="3"
                                    Height="24"
                                       Text="{Binding Address.Number, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                       TextChanged="OnAnyTextChanged"/>

                            <TextBlock Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,6,0,2"
                                    Text="{x:Static properties:Resources.Form_City}"/>
                            <TextBox   Grid.Row="1"
                                    Grid.Column="1"
                                    Height="24"
                                    Margin="0,4,0,0"
                                       Text="{Binding Address.City, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                       TextChanged="OnAnyTextChanged"/>

                            <TextBlock Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="12,6,0,2"
                                    Text="{x:Static properties:Resources.Form_Country}"/>
                            <TextBox   Grid.Row="1"
                                    Grid.Column="3"
                                    Height="24"
                                    Margin="0,4,0,0"
                                       Text="{Binding Address.Country, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                       TextChanged="OnAnyTextChanged"/>
                        </Grid>
                    </GroupBox>

                    <!-- Phone -->
                    <TextBlock Grid.Row="4"
                            Grid.Column="0"
                            Margin="0,8,0,2"
                            Text="{x:Static properties:Resources.Form_Phone}"/>
                    <TextBox   Grid.Row="4"
                            Grid.Column="1"
                            Height="24"
                            Margin="0,6,0,0"
                               Text="{Binding Author.Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                               TextChanged="OnAnyTextChanged"/>

                    <!-- Email -->
                    <TextBlock Grid.Row="5"
                            Grid.Column="0"
                            Margin="0,6,0,2"
                            Text="{x:Static properties:Resources.Form_Email}"/>
                    <TextBox   Grid.Row="5"
                            Grid.Column="1"
                            Height="24"
                            Margin="0,4,0,0"
                               Text="{Binding Author.Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                               TextChanged="OnAnyTextChanged"/>

                    <!-- ID Card Number -->
                    <TextBlock Grid.Row="6"
                            Grid.Column="0"
                            Margin="0,6,0,2"
                            Text="{x:Static properties:Resources.Form_IDCardNumber}"/>
                    <TextBox   Grid.Row="6"
                            Grid.Column="1"
                            Height="24"
                            Margin="0,4,0,0"
                               Text="{Binding Author.IDCardNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                               TextChanged="OnAnyTextChanged"/>

                    <!-- Years of Experience -->
                    <TextBlock Grid.Row="7"
                            Grid.Column="0"
                            Margin="0,6,0,2"
                            Text="{x:Static properties:Resources.Form_YearsOfExperience}"/>
                    <TextBox   Grid.Row="7"
                            Grid.Column="1"
                            Height="24"
                            Margin="0,4,0,0"
                               Text="{Binding Author.YearsOfExperienceText, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                               TextChanged="OnAnyTextChanged"/>
                </Grid>
            </TabItem>

            <TabItem Header="{x:Static properties:Resources.TabBooks}">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,8">
                        <Button Content="{x:Static properties:Resources.FormBtn_AddBook}"
                                Width="90"
                                Margin="0,0,8,0"
                                Click="AddBook_Click"/>
                        <Button Content="{x:Static properties:Resources.FormBtn_RemoveBook}"
                                Width="90"
                                Margin="0,0,8,0"
                                Click="RemoveBook_Click"/>
                        <Button Content="{x:Static properties:Resources.FormBtn_ShowVisitors}"
                                Width="120"
                                Click="ShowVisitors_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              x:Name="AuthorBooksGrid"
                              ItemsSource="{Binding AuthorBooks}"
                              SelectedItem="{Binding SelectedAuthorBook, Mode=TwoWay}"
                              SelectionMode="Extended"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{x:Static properties:Resources.GridBooks_ISBN}"
                                    Binding="{Binding ISBN}"
                                    Width="*"/>
                            <DataGridTextColumn Header="{x:Static properties:Resources.GridBooks_Name}"
                                    Binding="{Binding Name}"
                                    Width="2*"/>
                            <DataGridTextColumn Header="{x:Static properties:Resources.GridBooks_YearOfRelease}"
                                    Binding="{Binding YearOfRelease}"
                                    Width="*"/>
                            <DataGridTextColumn Header="{x:Static properties:Resources.GridBooks_Genre}"
                                    Binding="{Binding Genre}"
                                    Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
