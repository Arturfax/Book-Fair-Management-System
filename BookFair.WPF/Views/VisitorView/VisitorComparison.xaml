<Window x:Class="BookFair.WPF.Views.VisitorView.VisitorComparison"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:BookFair.WPF.Properties"
        Title="{x:Static properties:Resources.MenuCompareVisitors}"
        Height="700"
        Width="950"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="12"
               LastChildFill="True">
        <Grid DockPanel.Dock="Top"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Text="{x:Static properties:Resources.Label_Book1}"/>
            <ComboBox Grid.Column="1"
                      x:Name="Book1Combo"
                      Width="200"
                      DisplayMemberPath="Name"/>
            <TextBlock Grid.Column="2"
                       VerticalAlignment="Center"
                       Margin="12,0,8,0"
                       Text="{x:Static properties:Resources.Label_Book2}"/>
            <ComboBox Grid.Column="3"
                      x:Name="Book2Combo"
                      Width="200"
                      DisplayMemberPath="Name"/>
            <Button Grid.Column="4"
                    Content="{x:Static properties:Resources.Btn_Compare}"
                    Width="100"
                    Margin="12,0,0,0"
                    Click="Compare_Click"/>

            <TextBox Grid.Column="6"
                     x:Name="SearchBox"
                     Width="185"
                     Height="24"
                     VerticalContentAlignment="Center"
                     ToolTip="{x:Static properties:Resources.SearchBoxTooltip}"
                     TextChanged="SearchBox_TextChanged"/>
        </Grid>

        <TabControl>
            <TabItem Header="{x:Static properties:Resources.Tab_WishlistBoth}">
                <DataGrid x:Name="BothWishlistGrid"
                          ItemsSource="{Binding FilteredBoth}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_MembershipCardNumber}"
                                            Binding="{Binding CardNumber}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_Name}"
                                            Binding="{Binding Name}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_Surname}"
                                            Binding="{Binding Surname}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_Status}"
                                            Binding="{Binding Status}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="{x:Static properties:Resources.Tab_BoughtFirstOnly}">
                <DataGrid x:Name="BoughtFirstGrid"
                          ItemsSource="{Binding FilteredBoughtOnly}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_MembershipCardNumber}"
                                            Binding="{Binding CardNumber}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_Name}"
                                            Binding="{Binding Name}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_Surname}"
                                            Binding="{Binding Surname}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_Status}"
                                            Binding="{Binding Status}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="{x:Static properties:Resources.MenuClose}"
                    Width="100"
                    Click="Close_Click"/>
        </StackPanel>
    </DockPanel>
</Window>