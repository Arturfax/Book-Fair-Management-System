<Window x:Class="BookFair.WPF.Views.VisitorView.PurchaseBookDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kupovina knjige"
        Height="260" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <DockPanel Margin="12">

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Odustani" Width="110" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button x:Name="BtnConfirm" Content="Potvrdi" Width="110" IsEnabled="False" Click="Confirm_Click"/>
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,4" Text="ISBN *"/>
            <TextBox Grid.Row="0" Grid.Column="1" Height="24"
                     IsReadOnly="True"
                     Text="{Binding ISBN, Mode=OneWay}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,4" Text="Naziv *"/>
            <TextBox Grid.Row="1" Grid.Column="1" Height="24" Margin="0,6,0,0"
                     IsReadOnly="True"
                     Text="{Binding BookName, Mode=OneWay}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,4" Text="Ocena *"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Height="26" Margin="0,6,0,0"
                      x:Name="RatingCombo"
                      SelectionChanged="OnInputChanged">
                <ComboBoxItem Content="5"/>
                <ComboBoxItem Content="6"/>
                <ComboBoxItem Content="7"/>
                <ComboBoxItem Content="8"/>
                <ComboBoxItem Content="9"/>
                <ComboBoxItem Content="10"/>
            </ComboBox>

            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,4" Text="Datum kupovine *"/>
            <DatePicker Grid.Row="3" Grid.Column="1" Height="24" Margin="0,6,0,0"
                        x:Name="BuyingDatePicker"
                        SelectedDateChanged="OnDateChanged"/>
        </Grid>

    </DockPanel>
</Window>
