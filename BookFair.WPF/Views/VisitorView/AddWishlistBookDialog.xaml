<Window x:Class="BookFair.WPF.Views.VisitorView.AddWishlistBookDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:BookFair.WPF.Properties"
        Title="{x:Static properties:Resources.FormTitle_AddWishlistBook}"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        MinWidth="420"
        MinHeight="300">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="LstBooks"
                 Grid.Row="0"
                 DisplayMemberPath="Display"
                 SelectionMode="Extended"
                 MinHeight="200"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{x:Static properties:Resources.FormBtn_Cancel}" Width="110" Margin="0,0,10,0" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="{x:Static properties:Resources.FormBtn_Confirm}" Width="110" IsDefault="True" Click="Add_Click"/>
        </StackPanel>
    </Grid>
</Window>
