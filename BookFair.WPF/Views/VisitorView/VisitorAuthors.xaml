<Window x:Class="BookFair.WPF.Views.VisitorView.VisitorAuthors"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:BookFair.WPF.Properties"
        Title="{x:Static properties:Resources.VisitorAuthors_WindowDefaultTitle}"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="12"
            LastChildFill="True">
        <!-- Search and Buttons -->
        <StackPanel DockPanel.Dock="Top"
                Orientation="Horizontal"
                Margin="0,0,0,12">
            <TextBlock VerticalAlignment="Center"
                    Margin="0,0,8,0"
                    Text="{x:Static properties:Resources.PublisherBooks_SearchLabel}"/>
            <TextBox x:Name="SearchBox"
                    Width="300"
                    Height="24"
                     ToolTip="{x:Static properties:Resources.SearchBoxTooltip}"
                     TextChanged="SearchBox_TextChanged"/>
            <Button Content="{x:Static properties:Resources.MenuClose}"
                    Width="100"
                    Margin="12,0,0,0"
                    Click="Close_Click"/>
        </StackPanel>

        <!-- Data Grid -->
        <DataGrid DockPanel.Dock="Bottom"
                  x:Name="AuthorsGrid"
                  ItemsSource="{Binding FilteredAuthors}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static properties:Resources.GridAuthors_Name}"
                        Binding="{Binding Name}"
                        Width="*"/>
                <DataGridTextColumn Header="{x:Static properties:Resources.GridAuthors_Surname}"
                        Binding="{Binding Surname}"
                        Width="*"/>
                <DataGridTextColumn Header="{x:Static properties:Resources.GridAuthors_Email}"
                        Binding="{Binding Email}"
                        Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>