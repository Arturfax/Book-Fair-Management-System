<Window x:Class="BookFair.WPF.Views.VisitorView.AddVisitor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:BookFair.WPF.Properties"
        Title="{x:Static properties:Resources.FormTitle_NewVisitor}" Height="560" Width="620"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Crvena ivica i (bezbedan) tooltip sa porukom prve greške -->
        <Style TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="BorderBrush" Value="Red"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="ToolTip"
                    Value="{Binding Path=(Validation.Errors)[0].ErrorContent,
                                    RelativeSource={RelativeSource Self},
                                    FallbackValue=''}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Margin="12">

        <!-- Dugmad -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="Confirm" Content="{x:Static properties:Resources.FormBtn_Confirm}" Width="100" Margin="0,0,10,0"
                IsEnabled="False" Click="Add_Click"/>
            <Button Content="{x:Static properties:Resources.FormBtn_Cancel}" Width="100" Click="Close_Click"/>
        </StackPanel>

        <!-- Forma -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <!-- Adresa -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Ime/Prezime/Datum -->
            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,2" Text="{x:Static properties:Resources.Form_Name}"/>
            <TextBox   Grid.Row="0" Grid.Column="1" Height="24"
                   Text="{Binding Visitor.Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                   TextChanged="OnAnyTextChanged"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,2" Text="{x:Static properties:Resources.Form_Surname}"/>
            <TextBox   Grid.Row="1" Grid.Column="1" Height="24" Margin="0,4,0,0"
                   Text="{Binding Visitor.Surname, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                   TextChanged="OnAnyTextChanged"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,0,2" Text="{x:Static properties:Resources.Form_DateOfBirth}"/>
            <DatePicker Grid.Row="2" Grid.Column="1" Height="24" Margin="0,4,0,0"
                   ToolTip="yyyy-MM-dd"
                   SelectedDate="{Binding Visitor.DateOfBirth, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                   SelectedDateChanged="OnAnyTextChanged"/>

            <!-- ADRESA -->
            <GroupBox Grid.Row="3" Grid.ColumnSpan="2" Header="{x:Static properties:Resources.Form_Address}" Margin="0,8,0,0">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,2" Text="{x:Static properties:Resources.Form_Street}"/>
                    <TextBox   Grid.Row="0" Grid.Column="1" Height="24"
                           Text="{Binding Address.Street, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                           TextChanged="OnAnyTextChanged"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Margin="12,2,0,2" Text="{x:Static properties:Resources.Form_Number}"/>
                    <TextBox   Grid.Row="0" Grid.Column="3" Height="24"
                           Text="{Binding Address.Number, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                           TextChanged="OnAnyTextChanged"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,2" Text="{x:Static properties:Resources.Form_City}"/>
                    <TextBox   Grid.Row="1" Grid.Column="1" Height="24" Margin="0,4,0,0"
                           Text="{Binding Address.City, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                           TextChanged="OnAnyTextChanged"/>

                    <TextBlock Grid.Row="1" Grid.Column="2" Margin="12,6,0,2" Text="{x:Static properties:Resources.Form_Country}"/>
                    <TextBox   Grid.Row="1" Grid.Column="3" Height="24" Margin="0,4,0,0"
                           Text="{Binding Address.Country, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                           TextChanged="OnAnyTextChanged"/>
                </Grid>
            </GroupBox>

            <!-- Telefon / Email -->
            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,0,2" Text="{x:Static properties:Resources.Form_Phone}"/>
            <TextBox   Grid.Row="4" Grid.Column="1" Height="24" Margin="0,6,0,0"
                   Text="{Binding Visitor.Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                   TextChanged="OnAnyTextChanged"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6,0,2" Text="{x:Static properties:Resources.Form_Email}"/>
            <TextBox   Grid.Row="5" Grid.Column="1" Height="24" Margin="0,4,0,0"
                   Text="{Binding Visitor.Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                   TextChanged="OnAnyTextChanged"/>

            <!-- Broj Clanske Karte -->
            <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,6,0,2" Text="{x:Static properties:Resources.Form_MembershipCardNumber}"/>
            <TextBox   Grid.Row="6" Grid.Column="1" Height="24" Margin="0,4,0,0"
                   ToolTip="npr: SK-01-2022"
                   Text="{Binding Visitor.MembershipCardNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                   TextChanged="OnAnyTextChanged"/>

            <!-- Status -->
            <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,6,0,2" Text="{x:Static properties:Resources.Form_Status}"/>
            <ComboBox  Grid.Row="8" Grid.Column="1" Height="26" Margin="0,4,0,0"
                   SelectedIndex="{Binding Visitor.StatusBinding, Mode=TwoWay}"
                   SelectionChanged="OnAnyTextChanged">
                <ComboBoxItem>R</ComboBoxItem>
                <ComboBoxItem>V</ComboBoxItem>
            </ComboBox>
        </Grid>
    </DockPanel>
</Window>
