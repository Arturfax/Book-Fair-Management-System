<Window x:Class="BookFair.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:BookFair.WPF.Properties"
        xmlns:helpers="clr-namespace:BookFair.WPF.Helpers"
        Title="{x:Static properties:Resources.MainWindowTitle}"
        WindowStartupLocation="CenterScreen"
        Height="650"
        Width="1050"
        PreviewKeyDown="Window_PreviewKeyDown">

        <!-- Keyboard Shortcuts -->
        <Window.InputBindings>
                <KeyBinding Key="N"
                            Modifiers="Ctrl"
                            Command="{Binding NewCommand}"/>
                <KeyBinding Key="S"
                            Modifiers="Ctrl"
                            Command="{Binding SaveCommand}"/>
                <KeyBinding Key="E"
                            Modifiers="Ctrl"
                            Command="{Binding EditCommand}"/>
                <KeyBinding Key="Delete"
                            Command="{Binding DeleteCommand}"/>
        </Window.InputBindings>

        <Window.Resources>
                <helpers:GenreConverter x:Key="GenreConverter"/>
        </Window.Resources>

        <DockPanel LastChildFill="True">
                <!-- Menu -->
                <Menu DockPanel.Dock="Top">
                        <MenuItem Header="{x:Static properties:Resources.MenuFile}">
                                <MenuItem Header="{x:Static properties:Resources.MenuNew}"
                                          Click="OnNewClick"
                                          InputGestureText="Ctrl+N">
                                        <MenuItem.Icon>
                                                <Image Source="/images/new.png"
                                                       Width="16"
                                                       Height="16"/>
                                        </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{x:Static properties:Resources.MenuSave}"
                                          Click="OnSaveClick"
                                          InputGestureText="Ctrl+S">
                                        <MenuItem.Icon>
                                                <Image Source="/images/add.png"
                                                       Width="16"
                                                       Height="16"/>
                                        </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{x:Static properties:Resources.MenuOpen}">
                                        <MenuItem.Icon>
                                                <Image Source="/images/open.png"
                                                       Width="16"
                                                       Height="16"/>
                                        </MenuItem.Icon>
                                        <MenuItem Header="{x:Static properties:Resources.MenuOpenVisitors}"
                                                  Click="OnOpenVisitors"/>
                                        <MenuItem Header="{x:Static properties:Resources.MenuOpenBooks}"
                                                  Click="OnOpenBooks"/>
                                        <MenuItem Header="{x:Static properties:Resources.MenuOpenAuthors}"
                                                  Click="OnOpenAuthors"/>
                                        <MenuItem Header="{x:Static properties:Resources.MenuOpenPublishers}"
                                                        Click="OnOpenPublishers"/>
                                </MenuItem>
                                <MenuItem Header="{x:Static properties:Resources.MenuSetPublisherHead}"
                                          Click="OnSetPublisherHead"/>
                                <MenuItem Header="{x:Static properties:Resources.MenuCompareVisitors}"
                                          Click="OnCompareVisitors"/>
                                <MenuItem Header="{x:Static properties:Resources.MenuPublisherBooks}"
                                          Click="OnShowPublisherBooks"/>
                                <MenuItem Header="{x:Static properties:Resources.MenuPublisherAuthors}"
                                          Click="OnShowPublisherAuthors"/>
                                <Separator/>
                                <MenuItem Header="{x:Static properties:Resources.MenuClose}"
                                          Click="OnCloseClick"
                                          InputGestureText="Alt+F4">
                                        <MenuItem.Icon>
                                                <Image Source="/images/close.png"
                                                       Width="16"
                                                       Height="16"/>
                                        </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{x:Static properties:Resources.MenuLanguage}">
                                        <MenuItem.Icon>
                                                <Image Source="/images/language.png"
                                                       Width="16"
                                                       Height="16"/>
                                        </MenuItem.Icon>
                                        <MenuItem Header="{x:Static properties:Resources.MenuEnglish}"
                                                  Click="SetLanguage_En"/>
                                        <MenuItem Header="{x:Static properties:Resources.MenuSerbian}"
                                                  Click="SetLanguage_Sr"/>
                                </MenuItem>

                        </MenuItem>
                        <MenuItem Header="{x:Static properties:Resources.MenuEdit}">
                                <MenuItem Header="{x:Static properties:Resources.MenuEditModify}"
                                          Click="OnEditClick"
                                          InputGestureText="Ctrl+E">
                                        <MenuItem.Icon>
                                                <Image Source="/images/edit.png"
                                                       Width="16"
                                                       Height="16"/>
                                        </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{x:Static properties:Resources.MenuEditDelete}"
                                          Click="OnDeleteClick"
                                          InputGestureText="Del">
                                        <MenuItem.Icon>
                                                <Image Source="/images/delete.png"
                                                       Width="16"
                                                       Height="16"/>
                                        </MenuItem.Icon>
                                </MenuItem>
                        </MenuItem>
                        <MenuItem Header="{x:Static properties:Resources.MenuHelp}">
                                <MenuItem Header="{x:Static properties:Resources.MenuHelpAbout}"
                                          Click="OnAboutClick">
                                        <MenuItem.Icon>
                                                <Image Source="/images/help.png"
                                                       Width="16"
                                                       Height="16"/>
                                        </MenuItem.Icon>
                                </MenuItem>
                        </MenuItem>
                </Menu>
                <!-- Toolbar -->
                <Grid DockPanel.Dock="Top"
                      Height="30"
                      Background="#FFF0F0F0">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    Margin="4,2">
                                <Button Name="BtnNew"
                                        Click="OnNewClick"
                                        ToolTip="{x:Static properties:Resources.BtnNewTooltip}"
                                        Margin="2,0">
                                        <Image Width="16"
                                               Height="16"
                                               Source="/images/new.png"/>
                                </Button>
                                <Button Name="BtnEdit"
                                        Click="OnEditClick"
                                        ToolTip="{x:Static properties:Resources.BtnEditTooltip}"
                                        Margin="2,0">
                                        <Image Width="16"
                                               Height="16"
                                               Source="/images/edit.png"/>
                                </Button>
                                <Button Name="BtnDelete"
                                        Click="OnDeleteClick"
                                        ToolTip="{x:Static properties:Resources.BtnDeleteTooltip}"
                                        Margin="2,0">
                                        <Image Width="16"
                                               Height="16"
                                               Source="/images/delete.png"/>
                                </Button>
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    Margin="4,2">
                                <TextBox Name="SearchBox"
                                         Width="185"
                                         Margin="0,0,6,0"
                                         VerticalContentAlignment="Center"
                                         ToolTip="{x:Static properties:Resources.SearchBoxTooltip}"/>
                                <Button Name="BtnSearch"
                                        Click="OnSearchClick"
                                        ToolTip="{x:Static properties:Resources.BtnSearchTooltip}"
                                        Width="28"
                                        Margin="0,0,4,0">
                                        <Image Width="16"
                                               Height="16"
                                               Source="/images/search.png"/>
                                </Button>
                        </StackPanel>
                </Grid>
                <!-- Tabs -->
                <TabControl Name="MainTabs"
                            DockPanel.Dock="Top"
                            SelectionChanged="OnTabChanged">
                        <!-- VISITORS -->
                        <TabItem Header="{x:Static properties:Resources.TabVisitors}"
                                 Name="TabVisitors">
                                <DockPanel LastChildFill="True"
                                           Background="#FFF6FD">
                                        <StackPanel Orientation="Horizontal"
                                                    DockPanel.Dock="Bottom"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,6,8,8">
                                                <Button Content="⟨"
                                                        Width="26"
                                                        Click="OnPrevPageClick"
                                                        Height="31"/>
                                                <TextBlock Name="VisitorsPageInfo"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0"
                                                           FontWeight="Bold"/>
                                                <Button Content="⟩"
                                                        Width="26"
                                                        Click="OnNextPageClick"
                                                        Height="31"/>
                                        </StackPanel>
                                        <DataGrid Name="GridVisitors"
                                                  Margin="8"
                                                  AutoGenerateColumns="False"
                                                  ItemsSource="{Binding Visitors}"
                                                  SelectedItem="{Binding SelectedVisitor, Mode=TwoWay}"
                                                  SelectionMode="Single"
                                                  IsReadOnly="True"
                                                  Sorting="OnGridSorting">
                                                <DataGrid.Columns>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_MembershipCardNumber}"
                                                                            Binding="{Binding MembershipCardNumber }"
                                                                            Width="*"/>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_Name}"
                                                                            Binding="{Binding Name}"
                                                                            Width="*"/>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_Surname}"
                                                                            Binding="{Binding Surname}"
                                                                            Width="*"/>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_Address}"
                                                                            Binding="{Binding Address}"
                                                                            Width="*"/>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridVisitors_Status}"
                                                                            Binding="{Binding Status}"
                                                                            Width="*"/>
                                                </DataGrid.Columns>
                                        </DataGrid>
                                </DockPanel>
                        </TabItem>
                        <!-- BOOKS -->
                        <TabItem Header="{x:Static properties:Resources.TabBooks}"
                                 Name="TabBooks">
                                <DockPanel LastChildFill="True"
                                           Background="#FFF6FD">
                                        <StackPanel Orientation="Horizontal"
                                                    DockPanel.Dock="Bottom"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,6,8,8">
                                                <Button Content="⟨"
                                                        Width="26"
                                                        Click="OnPrevPageClick"
                                                        Height="31"/>
                                                <TextBlock Name="BooksPageInfo"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0"
                                                           FontWeight="Bold"/>
                                                <Button Content="⟩"
                                                        Width="26"
                                                        Click="OnNextPageClick"
                                                        Height="31"/>
                                        </StackPanel>
                                        <DataGrid Name="GridBooks"
                                                  Margin="8"
                                                  AutoGenerateColumns="False"
                                                  ItemsSource="{Binding Books}"
                                                  SelectedItem="{Binding SelectedBook, Mode=TwoWay}"
                                                  SelectionMode="Single"
                                                  IsReadOnly="True"
                                                  Sorting="OnGridSorting">
                                                <DataGrid.Columns>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridBooks_ISBN}"
                                                                            Binding="{Binding ISBN}"
                                                                            Width="*"/>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridBooks_Name}"
                                                                            Binding="{Binding Name}"
                                                                            Width="*"/>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridBooks_Price}"
                                                                            Binding="{Binding Price}"
                                                                            Width="*"/>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridBooks_YearOfRelease}"
                                                                            Binding="{Binding YearOfRelease}"
                                                                            Width="*"/>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridBooks_Genre}"
                                                                            Binding="{Binding Genre, Converter={StaticResource GenreConverter}}"
                                                                            Width="*"/>
                                                </DataGrid.Columns>
                                        </DataGrid>
                                </DockPanel>
                        </TabItem>
                        <!-- AUTHORS -->
                        <TabItem Header="{x:Static properties:Resources.TabAuthors}"
                                 Name="TabAuthors">
                                <DockPanel LastChildFill="True"
                                           Background="#FFF6FD">
                                        <StackPanel Orientation="Horizontal"
                                                    DockPanel.Dock="Bottom"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,6,8,8">
                                                <Button Content="⟨"
                                                        Width="26"
                                                        Click="OnPrevPageClick"
                                                        Height="31"/>
                                                <TextBlock Name="AuthorsPageInfo"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0"
                                                           FontWeight="Bold"/>
                                                <Button Content="⟩"
                                                        Width="26"
                                                        Click="OnNextPageClick"
                                                        Height="31"/>
                                        </StackPanel>
                                        <DataGrid Name="GridAuthors"
                                                  Margin="8"
                                                  AutoGenerateColumns="False"
                                                  ItemsSource="{Binding Authors}"
                                                  SelectedItem="{Binding SelectedAuthor, Mode=TwoWay}"
                                                  SelectionMode="Single"
                                                  IsReadOnly="True"
                                                  Sorting="OnGridSorting">
                                                <DataGrid.Columns>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridAuthors_Name}"
                                                                            Binding="{Binding Name}"
                                                                            Width="*"/>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridAuthors_Surname}"
                                                                            Binding="{Binding Surname}"
                                                                            Width="*"/>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridAuthors_IdCardNumber}"
                                                                            Binding="{Binding IDCardNumber}"
                                                                            Width="*"/>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridAuthors_DateOfBirth}"
                                                                            Binding="{Binding DateOfBirth}"
                                                                            Width="*"/>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridAuthors_Email}"
                                                                            Binding="{Binding Email}"
                                                                            Width="*"/>
                                                </DataGrid.Columns>
                                        </DataGrid>
                                </DockPanel>
                        </TabItem>
                        <!-- PUBLISHERS -->
                        <TabItem Header="{x:Static properties:Resources.TabPublishers}"
                                        Name="TabPublishers">
                                <DockPanel LastChildFill="True"
                                                Background="#FFF6FD">
                                        <StackPanel Orientation="Horizontal"
                                                    DockPanel.Dock="Bottom"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,6,8,8">
                                                <Button Content="⟨"
                                                                Width="26"
                                                                Click="OnPrevPageClick"
                                                                Height="31"/>
                                                <TextBlock Name="PublishersPageInfo"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0"
                                                           FontWeight="Bold"/>
                                                <Button Content="⟩"
                                                                Width="26"
                                                                Click="OnNextPageClick"
                                                                Height="31"/>
                                        </StackPanel>
                                        <DataGrid Name="GridPublishers"
                                                  Margin="8"
                                                  AutoGenerateColumns="False"
                                                  ItemsSource="{Binding Publishers}"
                                                  SelectedItem="{Binding SelectedPublisher, Mode=TwoWay}"
                                                  SelectionMode="Single"
                                                  IsReadOnly="True"
                                                  Sorting="OnGridSorting">
                                                <DataGrid.Columns>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridPublishers_Code}"
                                                                        Binding="{Binding Code}"
                                                                        Width="*"/>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.Publishers_Name}"
                                                                        Binding="{Binding Name}"
                                                                        Width="2*"/>
                                                        <DataGridTextColumn Header="{x:Static properties:Resources.GridPublishers}"
                                                                        Binding="{Binding HeadAuthorName}"
                                                                        Width="*"/>
                                                </DataGrid.Columns>
                                        </DataGrid>
                                </DockPanel>
                        </TabItem>
                </TabControl>
                <!-- STATUS BAR -->
                <StatusBar Background="#FFF6FD"
                           DockPanel.Dock="Bottom"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Stretch">
                        <StatusBar.ItemsPanel>
                                <ItemsPanelTemplate>
                                        <DockPanel LastChildFill="True"/>
                                </ItemsPanelTemplate>
                        </StatusBar.ItemsPanel>
                        <StatusBarItem DockPanel.Dock="Right">
                                <StackPanel Orientation="Horizontal">
                                        <Label Name="Date"
                                               Content="{x:Static properties:Resources.StatusBar_Date}"
                                               Width="90"
                                               Height="25"/>
                                        <Label Name="Time"
                                               Content="{x:Static properties:Resources.StatusBar_Time}"
                                               Width="60"
                                               Height="25"/>
                                </StackPanel>
                        </StatusBarItem>
                        <StatusBarItem>
                                <TextBlock x:Name="StatusAppAndTab"
                                           Text="{x:Static properties:Resources.StatusBar_Main}"/>
                        </StatusBarItem>
                </StatusBar>
        </DockPanel>
</Window>
